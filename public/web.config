<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <rewrite>
            <rules>
                <!-- Rule to redirect root requests to /login -->
                <rule name="Redirect Root to Login" stopProcessing="true">
                    <match url="^$" ignoreCase="true" />
                    <action type="Redirect" url="/mosip/login" redirectType="Found" />
                </rule>

                <!-- Rule to handle static files that should be served directly -->
                <rule name="Static Files" stopProcessing="true">
                    <match url=".*\.(css|js|png|jpg|gif|svg|ico)$" />
                    <action type="None" />
                </rule>

                <!-- Pass everything else to Laravel index.php -->
                <rule name="Laravel" stopProcessing="true">
                    <match url="^(.*)$" ignoreCase="false" />
                    <action type="Rewrite" url="/mosip/public/index.php/{R:1}" />
                </rule>
            </rules>
        </rewrite>
    </system.webServer>
</configuration>
